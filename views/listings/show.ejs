<% layout("/layouts/boilerplate.ejs")%>
<body>
    <div class="row offset-xl-2 offset-lg-1">
    
    <div class="col-xl-9 col-lg-10">
       <h2 style="color: #1A2E2F;"><%=listing.title%></h2>
       <div class="card show-card" >
      <img src="<%=listing.image.url%>" class="card-img-top show-image" alt="listing image">
      <div class="card-body">
      <p class="card-text">
        <%=listing.description%> <br>
        &#8377; <%=listing.price.toLocaleString("en-IN")%> <br>
        <%=listing.country%> <br>
        <%=listing.location%> <br>
        </p>
      </div>
      </div>
  <div class=" mb-3 mt-3">
<!-- class="col-sm-3" class="row mb-3 mt-3"-->
<div class="ms-1" style="display: inline-block;"><a href="/listings/<%=listing._id%>/edit" class="btn btn-dark listing-btns ">Edit</a></div>
 <div class="ms-3" style="display: inline-block;">
            <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
            <button class="btn btn-dark ">Delete</button>
            </form>
 </div>
</div>
 </div>


    <div class="col-xl-9 col-lg-10 mt-3 " >
        <!-- class rating-container -->
       <form action="/listings/<%= listing._id %>/review" method="post" novalidate class="needs-validation">

        <h3 class="rating-label">Rate this property</h3>
  
        <div class="rating-stars ">
            
  <input class="form-check-input" type="checkbox" id="1star" value="1" name="review[rating]">
  <label for="1star" class="star">★</label>
  
  <input class="form-check-input" type="checkbox" id="2star" value="2" name="review[rating]">
  <label for="2star" class="star">★</label>
  
  <input class="form-check-input" type="checkbox" id="3star" value="3" name="review[rating]">
  <label for="3star" class="star">★</label>
  
  <input class="form-check-input" type="checkbox" id="4star" value="4" name="review[rating]">
  <label for="4star" class="star">★</label>
  
  <input class="form-check-input " type="checkbox" id="5star" value="5" name="review[rating]" >
  <label for="5star" class="star">★</label>
</div>

     <div class="mb-3">
            <!-- <label for="description" class="form-label">description</label> -->
            <textarea  placeholder="Share your experience..." maxlength="500" name="review[comment]" rows="9" class="form-control review-text" required></textarea>
 <div class="invalid-feedback">
      Please leave a valid comment.
    </div></div>

<button type="submit" class="rating-btn" disabled>Submit</button>
       </form>
    </div>


    <div class="col-xl-9 col-lg-10 my-3">
  <%if(listing.reviews.length){%>
<h4>All reviews</h4>
<div class="row ">
<%for(review of listing.reviews){%>
   <!-- <h6><%=review%></h6> -->
  <div class="col-md-6 my-2">
    
     <div class="review-card card">
         
          <!-- Star Rating Display -->
          <div class="review-header card-body">
            <h5 class="card-title">Card title</h5>
            <div class="review-stars">
              <% for (let i = 1; i <= 5; i++) { %>
                <span class="star <%= i <= review.rating ? 'filled' : 'empty' %>">★</span>
              <% } %>
              <span class="review-rating"><%= review.rating %>/5</span>
            </div>
          
          
          <!-- Review Comment -->
          <p class="review-comment card-text"><%= review.comment %></p>
        </div></div>

</div>

<%}%>
  <%}%>
  </div>
  </div>
  
  </div>
 <script src="/js/form-validator.js"></script>
 <script src="/js/rating.js"></script>
</body>
