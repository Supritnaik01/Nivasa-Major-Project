<% layout("/layouts/boilerplate.ejs")%>
<body>
    <div class="row mt-3 form-main-container">
        <div class="col-md-8 offset-md-2 form-wrapper">
     <h3>Edit Listing</h3>
    <form action="/listings/<%=listing._id%>?_method=put" method="post" novalidate class="needs-validation">

        <div class="mb-3">
            <label for="title" class="form-label" >Title</label>
            <input name="listing[title]" type="text" class="form-control" id="title" value="<%=listing.title%>" required>
            <div class="invalid-feedback">
            *Please enter a valid title
            </div>
        </div>
        <div class="mb-3">
            <label for="description" class="form-label">description</label>
            <textarea   id="description" class="form-control"  name="listing[description]" required><%=listing.description%></textarea>
            <div class="invalid-feedback">
            *Please enter a valid description
            </div>
        </div>
        <div class="mb-3">
            <label for="image" class="form-label">Image Url</label>
            <input  name="listing[image][url]" type="text" id="image" class="form-control" value="<%=listing.image.url%>" required>
            <div class="invalid-feedback">
            *Please enter a valid image url
            </div>
        </div>
        <div class="row">
        <div class="mb-3 col-md-5">
            <label for="price" class="form-label">Price</label>
            <input  name="listing[price]" type="number" id="price" class="form-control" value="<%=listing.price%>" required>
            <div class="invalid-feedback">
              *Please enter a valid Price
            </div>
        </div>
        <div class="mb-3 col-md-7">
            <label for="country" class="form-label">Country</label>
            <input  name="listing[country]" type="text" id="country" class="form-control" value="<%=listing.country%>" required>
            <div class="invalid-feedback">
             *Please enter a valid Country
           </div>
        </div>
        </div>
        <div class="mb-3">
            <label for="location" class="form-label" >Location</label>
             <input  name="listing[location]" type="text" id="location" class="form-control" value="<%=listing.location%>" required>
             <div class="invalid-feedback">
                *Please enter a valid location
            </div>
        </div>
       
        <button class="btn mt-3 listing-btns">Edit</button>

<script src="/js/form-validator.js"></script>




        <!-- <input placeholder="enter title" name="listing[title]" type="text" <br>
        <textarea name="listing[description]" placeholder="enter description" ></textarea><br>
        <input placeholder="enter image url" name="listing[image]" type="text" <br>
        <input placeholder="enter price" name="listing[price]" type="number" <br>
        <input placeholder="enter country" name="listing[country]" type="text" <br>
        <input placeholder="enter location" name="listing[location]" type="text" <br>
        <button>post</button> -->
    </form>
    </div></div>
</body>
