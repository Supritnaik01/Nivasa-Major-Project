<% layout("/layouts/boilerplate.ejs")%>
<body>
    <div class="row mt-3 form-main-container">
        <div class="col-8 offset-2 form-wrapper">
            <h3>Create a New Listing</h3>
    <form action="/listings" method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input placeholder="e.g., Cozy apartment in downtown" name="listing[title]" type="text" class="form-control" id="title" required>
            <div class="invalid-feedback">
            *Please enter a valid title
            </div>
        </div>
        <div class="mb-3">
            <label for="description" class="form-label">description</label>
            <textarea name="listing[description]" placeholder="Describe your property in detail..." id="description" class="form-control" required></textarea>
            <div class="invalid-feedback">
            *Please enter a valid description
            </div>
        </div>
        <div class="mb-3">
            <label for="image" class="form-label">Image Url</label>
            <input placeholder="https://example.com/image.jpg" name="listing[image]" type="text" id="image"  >
        </div>
        <div class="row">
        <div class="mb-3 col-md-5">
            <label for="price" class="form-label">Price</label>
            <input placeholder="0.00" name="listing[price]" type="number" id="price" class="form-control" required>
            <div class="invalid-feedback">
              *Please enter a valid Price
            </div>
        </div>
        <div class="mb-3 col-md-7">
            <label for="country" class="form-label">Country</label>
            <input placeholder="e.g., India" name="listing[country]" type="text" id="country" class="form-control" required>
            <div class="invalid-feedback">
             *Please enter a valid Country
           </div>
        </div>
        </div>
        <div class="mb-3">
            <label for="location" class="form-label">Location</label>
             <input placeholder="City, State or Region" name="listing[location]" type="text" id="location" class="form-control" required>
             <div class="invalid-feedback">
                *Please enter a valid location
            </div>
        </div><br>
       
        <button class="btn  listing-btns">Add Listing</button>
    </form>
    </div></div>
</body>

<script src="/js/form-validator.js"></script>